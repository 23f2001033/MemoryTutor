GEMINI_API_KEY=your-google-ai-studio-key-here

# Optional overrides (defaults shown).
# gemini-1.5-flash and text-embedding-004 have been retired by Google, so
# MemoryTutor defaults to current equivalents with generous free-tier quotas.
# If you have a paid key, gemini/gemini-2.5-flash gives higher-quality answers
# (free tier caps it at ~20 requests/day, which is too low for normal use).
LLM_MODEL=gemini/gemini-flash-lite-latest
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
